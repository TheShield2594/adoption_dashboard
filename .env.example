# Copy to .env and fill in real values. .env is gitignored — never commit real secrets.
# docker compose reads this file automatically when it sits next to docker-compose.yml.

# Discord webhook the weekly grant-fetch job posts its summary to.
DISCORD_WEBHOOK_URL=

# OpenRouter API key used to extract structured grant data from scraped pages.
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# Base URL of a SearXNG instance with JSON output enabled (search: formats:
# [html, json] in searxng settings.yml). Used to discover grant pages beyond
# the fixed source list. Leave blank to skip web-search discovery.
SEARXNG_URL=

# Cron expression (in the container's local time, UTC by default) for the
# weekly grant-fetch job. Default: Mondays at 17:00 UTC.
GRANT_FETCH_CRON=0 17 * * 1
